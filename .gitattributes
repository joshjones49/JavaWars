# Normalize text files and let Git handle platform-specific checkouts
* text=auto

# Keep source/config/docs with LF in the repository and working tree
*.java text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep Windows scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

